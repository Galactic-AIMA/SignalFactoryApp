# =============================================================================
# SignalFactory — Variables de entorno
# Copiar este archivo como .env y completar los valores
# =============================================================================

# --- PEXELS API (fondos de video) ---
# Requerida solo para DESCARGAR nuevos backgrounds desde Pexels.
# Sin esta key, la app usa los fondos ya guardados en assets/backgrounds/
# (pedir carpeta assets/ a Camilo vía Drive).
# Obtener key gratis en: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# --- N8N WEBHOOK (subida automática a YouTube) ---
# URL del webhook trigger del workflow "YouTube Upload" en n8n.
# Sin esta key, los videos se renderizan localmente en output/{es,en}/
# pero NO se suben automáticamente a YouTube.
# Obtener en: n8n.galacticaima.com → workflow YouTube Upload → nodo Webhook → copiar URL
N8N_WEBHOOK_URL=https://n8n.galacticaima.com/webhook/COMPLETAR

# --- CLOUDFLARE R2 (almacenamiento de videos para n8n) ---
# Después de cada render, el video se sube a R2 y se envía la URL pública al webhook.
# Obtener en: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=signalfactory-videos
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# --- BASE DE DATOS Y OUTPUT ---
DATABASE_PATH=./data/signalfactory.db
OUTPUT_DIR=./output

# =============================================================================
# MODO OFFLINE (sin ninguna key configurada):
#   - La app levanta y el dashboard funciona
#   - Se pueden renderizar videos usando assets locales (carpeta assets/)
#   - Los videos quedan en output/es/ y output/en/
#   - No hay descarga de nuevos fondos ni subida automática a YouTube
# =============================================================================
